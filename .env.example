# Токен бота от @BotFather (обязательно)
BOT_TOKEN=123456:ABC-DEF...

# Часовой пояс
TZ=Europe/Moscow

# Как часто кормим (дней)
FEED_INTERVAL_DAYS=3

# Дневное окно напоминаний (часы, 24ч формат). Окно: [START, END)
REMIND_START_HOUR=10
REMIND_END_HOUR=22

# Как часто повторять напоминание внутри окна (минут)
REMIND_EVERY_MINUTES=60

# Путь к файлу базы (по умолчанию turtle.db рядом с ботом)
DB_PATH=turtle.db
